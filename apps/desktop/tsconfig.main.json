{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["node"],
    "target": "ES2020",
    "lib": ["ES2020"],
    "noEmit": false,
    "sourceMap": false
  },
  "include": ["src/main/**/*.ts", "src/preload/**/*.ts"]
}

