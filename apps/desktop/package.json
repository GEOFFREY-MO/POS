{
  "name": "@offline-pos/desktop",
  "version": "0.1.1",
  "private": true,
  "type": "commonjs",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:renderer\" \"pnpm run dev:main\"",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:main": "tsx watch src/main/index.ts",
    "build": "pnpm run build:renderer && pnpm run build:main",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "rebuild": "node scripts/rebuild-native.js",
    "package": "pnpm run rebuild && electron-builder --win",
    "lint": "echo \"add linting\""
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^8.0.0",
    "@tanstack/react-query": "^5.90.16",
    "better-sqlite3": "^12.5.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "fastify-swagger": "^5.2.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "nanoid": "^3.3.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^31.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.7.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}

